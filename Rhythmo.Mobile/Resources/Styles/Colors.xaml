<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Rhythmo design system -->
    <Color x:Key="RhythmBg">#0F1115</Color>
    <Color x:Key="RhythmBgDeep">#0B0D10</Color>
    <Color x:Key="RhythmTextMuted">#6B7280</Color>
    <Color x:Key="RhythmOverlay">#99000000</Color>
    <Color x:Key="RhythmSurface1">#181B22</Color>
    <Color x:Key="RhythmSurface2">#202431</Color>
    <Color x:Key="RhythmTextPrimary">#E7E9EE</Color>
    <Color x:Key="RhythmTextSecondary">#9AA6B2</Color>
    <Color x:Key="RhythmAccent">#22D3C5</Color>
    <Color x:Key="RhythmAccentHover">#1ABDAC</Color>
    <Color x:Key="RhythmViolet">#8B5CF6</Color>
    <Color x:Key="RhythmSuccess">#22C55E</Color>
    <Color x:Key="RhythmWarning">#F59E0B</Color>
    <Color x:Key="RhythmError">#EF7171</Color>
    <Color x:Key="RhythmGold">#FBBF24</Color>
    <Color x:Key="RhythmSilver">#9CA3AF</Color>
    <Color x:Key="RhythmPink">#EC4899</Color>
    <Color x:Key="RhythmBronze">#D97706</Color>

    <!-- Legacy keys mapped to Rhythmo tokens -->
    <Color x:Key="Primary">#22D3C5</Color>
    <Color x:Key="PrimaryDark">#1ABDAC</Color>
    <Color x:Key="PrimaryDarkText">#0F1115</Color>
    <Color x:Key="Secondary">#8B5CF6</Color>
    <Color x:Key="SecondaryDarkText">#E7E9EE</Color>
    <Color x:Key="Tertiary">#8B5CF6</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#22D3C5</Color>
    <Color x:Key="MidnightBlue">#0F1115</Color>
    <Color x:Key="OffBlack">#0F1115</Color>

    <Color x:Key="Gray100">#E7E9EE</Color>
    <Color x:Key="Gray200">#9AA6B2</Color>
    <Color x:Key="Gray300">#9AA6B2</Color>
    <Color x:Key="Gray400">#6B7280</Color>
    <Color x:Key="Gray500">#9AA6B2</Color>
    <Color x:Key="Gray600">#202431</Color>
    <Color x:Key="Gray900">#E7E9EE</Color>
    <Color x:Key="Gray950">#181B22</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
