    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource RhythmBg}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource RhythmBg}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource RhythmTextPrimary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource RhythmTextPrimary}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource RhythmTextSecondary}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource RhythmTextSecondary}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource RhythmSurface1}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource RhythmAccent}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource RhythmAccent}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource RhythmTextSecondary}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource RhythmBg}" />
        <Setter Property="BarTextColor" Value="{StaticResource RhythmTextPrimary}" />
        <Setter Property="IconColor" Value="{StaticResource RhythmAccent}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource RhythmSurface1}" />
        <Setter Property="BarTextColor" Value="{StaticResource RhythmAccent}" />
        <Setter Property="UnselectedTabColor" Value="{StaticResource RhythmTextSecondary}" />
        <Setter Property="SelectedTabColor" Value="{StaticResource RhythmAccent}" />
    </Style>

    <Style TargetType="Label" x:Key="RhythmH1">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource RhythmTextPrimary}" />
    </Style>
    <Style TargetType="Label" x:Key="RhythmH2">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="TextColor" Value="{StaticResource RhythmTextPrimary}" />
    </Style>
    <Style TargetType="Label" x:Key="RhythmH3">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="TextColor" Value="{StaticResource RhythmTextPrimary}" />
    </Style>
    <Style TargetType="Label" x:Key="RhythmCaption">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource RhythmTextSecondary}" />
    </Style>

    <Style TargetType="Border" x:Key="RhythmFieldBorder">
        <Setter Property="BackgroundColor" Value="{StaticResource RhythmSurface1}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="16" />
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="RhythmBtnPrimary">
        <Setter Property="TextColor" Value="{StaticResource RhythmBg}" />
        <Setter Property="BackgroundColor" Value="{StaticResource RhythmAccent}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="MinimumHeightRequest" Value="46" />
    </Style>

    <Style TargetType="Button" x:Key="RhythmBtnSecondary">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource RhythmAccent}" />
        <Setter Property="BorderColor" Value="{StaticResource RhythmAccent}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="46" />
        <Setter Property="Padding" Value="18,12" />
    </Style>

    <Style TargetType="Button" x:Key="RhythmBtnGhost">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource RhythmAccent}" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style TargetType="Button" x:Key="RhythmBtnFinish">
        <Setter Property="BackgroundColor" Value="{StaticResource RhythmViolet}" />
        <Setter Property="TextColor" Value="{StaticResource RhythmTextPrimary}" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinimumHeightRequest" Value="52" />
        <Setter Property="Padding" Value="20,14" />
    </Style>

</ResourceDictionary>
