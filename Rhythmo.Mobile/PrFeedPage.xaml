<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Rhythmo.Mobile.Controls"
             x:Class="Rhythmo.Mobile.PrFeedPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource RhythmBg}">

    <Grid Padding="{OnIdiom Phone='16,48,16,16', Default='28,22'}"
          RowDefinitions="Auto,Auto,*">

        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="12"
              HeightRequest="44"
              Margin="0,0,0,10">
            <Button x:Name="BackBtn"
                    Grid.Column="0"
                    BackgroundColor="{StaticResource RhythmSurface2}"
                    BorderWidth="0"
                    CornerRadius="14"
                    FontSize="16"
                    Padding="12,8"
                    Text="←"
                    TextColor="{StaticResource RhythmTextPrimary}"
                    SemanticProperties.Hint="Retour"
                    HorizontalOptions="Start"
                    VerticalOptions="Center" />

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="0"
                                 VerticalOptions="Center">
                <Label Style="{StaticResource RhythmH2}"
                       Text="Tous les PR" />
            </VerticalStackLayout>
        </Grid>

        <VerticalStackLayout Grid.Row="1"
                             Spacing="8"
                             Margin="0,0,0,10">
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout x:Name="FilterChipsHost"
                                       Spacing="6"
                                       Padding="0,2" />
            </ScrollView>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8">
                <controls:RhythmOptionSelector x:Name="UserFilterSelector"
                                               IsCompact="True"
                                               SelectedIndexChanged="OnUserFilterChanged" />
                <controls:RhythmOptionSelector x:Name="ExerciseFilterSelector"
                                               Grid.Column="1"
                                               IsCompact="True"
                                               SelectedIndexChanged="OnExerciseFilterChanged" />
            </Grid>
        </VerticalStackLayout>

        <RefreshView x:Name="PrRefresh"
                     Grid.Row="2">
            <ScrollView>
                <VerticalStackLayout x:Name="PrFeedHost"
                                     Spacing="0"
                                     Padding="0,0,0,32" />
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
