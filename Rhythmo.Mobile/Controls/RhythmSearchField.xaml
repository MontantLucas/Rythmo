<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Rhythmo.Mobile.Controls"
             x:Class="Rhythmo.Mobile.Controls.RhythmSearchField"
             x:Name="Self">
    <Border Style="{StaticResource RhythmFieldBorder}">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
            <Label Grid.Column="0"
                   Text="{x:Static local:RhythmSearchGlyphs.Search}"
                   FontFamily="{x:Static local:RhythmSearchGlyphs.Font}"
                   FontSize="20"
                   TextColor="{StaticResource RhythmTextSecondary}"
                   VerticalOptions="Center"
                   Margin="4,0,0,0" />
            <Entry x:Name="SearchEntry"
                   Grid.Column="1"
                   BackgroundColor="Transparent"
                   Margin="0,0,4,0"
                   ReturnType="Search"
                   Text="{Binding Source={x:Reference Self}, Path=Text, Mode=TwoWay}"
                   Placeholder="{Binding Source={x:Reference Self}, Path=Placeholder}" />
        </Grid>
    </Border>
</ContentView>
