<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Rhythmo.Mobile.Controls.RhythmOptionSelector"
             x:Name="Self">
    <Border x:Name="TriggerBorder"
            Padding="16,14"
            MinimumHeightRequest="48"
            BackgroundColor="{StaticResource RhythmSurface1}"
            StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="14" />
        </Border.StrokeShape>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTriggerTapped" />
        </Border.GestureRecognizers>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Label x:Name="ValueLabel"
                   FontFamily="OpenSansRegular"
                   FontSize="15"
                   TextColor="{StaticResource RhythmTextPrimary}"
                   VerticalOptions="Center"
                   LineBreakMode="TailTruncation"
                   MaxLines="2" />
            <Label Grid.Column="1"
                   FontSize="13"
                   Text="▾"
                   TextColor="{StaticResource RhythmTextSecondary}"
                   VerticalOptions="Center" />
        </Grid>
    </Border>
</ContentView>
