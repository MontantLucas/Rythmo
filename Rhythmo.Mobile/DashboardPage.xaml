<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Rhythmo.Mobile.DashboardPage"
             Title="Accueil"
             Shell.NavBarIsVisible="False">
    <RefreshView x:Name="DashRefresh">
        <ScrollView>
            <VerticalStackLayout Padding="{OnIdiom Phone='20', Default='28'}"
                               Spacing="24">

                <VerticalStackLayout Spacing="8">
                    <Label x:Name="GreetingLabel" Style="{StaticResource RhythmH1}" />
                    <Label Style="{StaticResource RhythmCaption}"
                           Text="Prêt pour ta prochaine séance ?" />
                </VerticalStackLayout>

                <Border Padding="20"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource RhythmSurface1}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">
                        <Label Style="{StaticResource RhythmCaption}" Text="Prochaine séance" />
                        <Label x:Name="NextSessionTitleLabel"
                               Style="{StaticResource RhythmH3}"
                               LineBreakMode="TailTruncation" />
                        <Label x:Name="NextSessionMetaLabel" Style="{StaticResource RhythmCaption}" />
                        <Button x:Name="StartSessionBtn"
                                Text="▶ Démarrer"
                                Clicked="OnStartNextClicked"
                                Margin="0,8,0,0" />
                        <Button Style="{StaticResource RhythmBtnGhost}"
                                Text="Voir toutes les séances →"
                                Clicked="OnGoSessionsClicked" />
                    </VerticalStackLayout>
                </Border>

                <Label Style="{StaticResource RhythmH3}" Text="Stats rapides (7 jours)" />

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Padding="14,16" StrokeThickness="0"
                            BackgroundColor="{StaticResource RhythmSurface2}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Style="{StaticResource RhythmCaption}" Text="Séances" />
                            <Label x:Name="StatSessionsLabel"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="22"
                                   TextColor="{StaticResource RhythmAccent}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Padding="14,16" StrokeThickness="0"
                            BackgroundColor="{StaticResource RhythmSurface2}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Style="{StaticResource RhythmCaption}" Text="Volume" />
                            <Label x:Name="StatVolumeLabel"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="18"
                                   TextColor="{StaticResource RhythmTextPrimary}"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" Padding="14,16" StrokeThickness="0"
                            BackgroundColor="{StaticResource RhythmSurface2}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Style="{StaticResource RhythmCaption}" Text="kcal" />
                            <Label x:Name="StatKcalLabel"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="22"
                                   TextColor="{StaticResource RhythmTextPrimary}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Padding="18,16" StrokeThickness="0"
                        BackgroundColor="{StaticResource RhythmSurface1}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Style="{StaticResource RhythmCaption}" Text="Série active" />
                            <Label x:Name="StreakLabel"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="18"
                                   TextColor="{StaticResource RhythmSuccess}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               VerticalOptions="Center"
                               FontSize="28"
                               Text="🔥"
                               Opacity="0.9" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Style="{StaticResource RhythmH3}"
                           Text="Historique récent"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Style="{StaticResource RhythmBtnGhost}"
                            Text="Stats →"
                            Clicked="OnGoStatsClicked" />
                </Grid>

                <VerticalStackLayout x:Name="RecentHistoryHost" Spacing="12" />

                <Border Padding="20"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource RhythmSurface2}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Style="{StaticResource RhythmCaption}"
                               Text="Action rapide" />
                        <Label FontFamily="OpenSansSemibold"
                               FontSize="17"
                               Text="Composer ou importer une séance"
                               TextColor="{StaticResource RhythmTextPrimary}" />
                        <Button Style="{StaticResource RhythmBtnSecondary}"
                                Text="Nouvelle séance"
                                Clicked="OnQuickNewSessionClicked" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
